{
  "name": "sukashawarma-outlet-suite",
  "version": "0.0.1",
  "private": true,
  "description": "Outlet Suite — digitalisasi operasional outlet Sukashawarma",
  "workspaces": ["packages/*", "apps/*"],
  "scripts": {
    "dev": "yarn workspaces foreach -p run dev",
    "build": "yarn workspaces foreach -p run build",
    "lint": "yarn workspaces foreach -p run lint",
    "type-check": "yarn workspaces foreach -p run type-check",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\""
  },
  "devDependencies": {
    "typescript": "^5.3.3",
    "tailwindcss": "^4.0.0",
    "postcss": "^8.4.32",
    "@types/node": "^20.10.6",
    "@types/react": "^18.2.45",
    "prettier": "^3.1.1"
  }
}
