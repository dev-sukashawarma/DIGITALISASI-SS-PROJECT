{
  "name": "sukashawarma-outlet-suite",
  "version": "0.0.1",
  "private": true,
  "description": "Outlet Suite — digitalisasi operasional outlet Sukashawarma",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "type-check": "npm run type-check --workspaces --if-present",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\""
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^20.10.6",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.15",
    "prettier": "^3.1.1",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.3.3"
  }
}

