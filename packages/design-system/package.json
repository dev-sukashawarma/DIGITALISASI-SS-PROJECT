{
  "name": "@suka/design-system",
  "version": "0.0.1",
  "description": "SUKA brand design tokens and UI components",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./tokens": {
      "types": "./src/tokens.ts",
      "default": "./src/tokens.ts"
    }
  },
  "files": ["dist", "src"],
  "scripts": {
    "build": "tsc && node -e \"console.log('✓ Build complete')\"",
    "type-check": "tsc --noEmit"
  },
  "devDependencies": {
    "typescript": "^5.3.3",
    "@types/react": "^18.2.45"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "tailwindcss": "^4.0.0"
  }
}
